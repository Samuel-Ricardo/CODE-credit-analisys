{
  "name": "vv-analise-credito",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:e2e": "cypress run --spec \"cypress/e2e/**/*.cy.ts\"",
    "test:e2e": "start-server-and-test dev http://localhost:3000 cy:run:e2e",
    "test:e2e:open": "start-server-and-test dev http://localhost:3000 cy:open",
    "ci": "npm run lint && npm run type-check && npm run test:coverage && npm run build",
    "ci:e2e": "start-server-and-test start http-get://127.0.0.1:3000 cy:run:e2e",
    "ci:full": "npm run ci && npm run ci:e2e"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.513.0",
    "next": "15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cypress/webpack-dev-server": "^5.6.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "cypress": "^15.14.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "jsdom": "^29.0.2",
    "start-server-and-test": "^3.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  }
}
